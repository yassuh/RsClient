RS_IMAGE=ubuntu-realityscan:v2.2.0.119039
RS_CONTAINER_NAME=rsclient
REALITYSCAN_DEB=RealityScan.deb
RS_HOST_DOWNLOADS=./host-data
RS_SKIP_PREFLIGHT=0

# Same distro host/container default.
# On WSL this is typically /usr/share/vulkan/icd.d (not /etc/vulkan/icd.d).
RS_HOST_VULKAN_ICD_PATH=/usr/share/vulkan/icd.d

# Cross-distro optional library passthrough.
RS_HOST_LIBGLX_NVIDIA_PATH=/lib/x86_64-linux-gnu/libGLX_nvidia.so.0
RS_HOST_LIBNVIDIA_GLCORE_PATH=/usr/lib/x86_64-linux-gnu/libnvidia-glcore.so.1

# WSLg Wayland optional settings (used with docker-compose.wslg.yml).
RS_WSLG_MOUNT_PATH=/mnt/wslg
RS_WSLG_WAYLAND_DISPLAY=wayland-0
RS_WSLG_XDG_RUNTIME_DIR=/mnt/wslg/runtime-dir
RS_WSLG_PULSE_SERVER=unix:/mnt/wslg/PulseServer
RS_WSLG_VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/lvp_icd.x86_64.json
